{
    "name": "dex-order-execution-engine",
    "version": "1.0.0",
    "description": "DEX Order Execution Engine with Raydium and Meteora routing",
    "main": "dist/server.js",
    "scripts": {
        "dev": "nodemon",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "migrate": "ts-node src/database/migrate.ts",
        "generate-wallet": "ts-node scripts/generate-wallet.ts",
        "check-balance": "ts-node scripts/check-balance.ts",
        "request-airdrop": "ts-node scripts/request-airdrop.ts"
    },
    "keywords": [
        "dex",
        "solana",
        "raydium",
        "meteora",
        "order-execution",
        "websocket"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@coral-xyz/anchor": "^0.32.1",
        "@fastify/cors": "^9.0.1",
        "@fastify/websocket": "^10.0.1",
        "@meteora-ag/dlmm": "^1.9.3",
        "@raydium-io/raydium-sdk-v2": "^0.2.32-alpha",
        "@solana/spl-token": "^0.4.14",
        "@solana/web3.js": "^1.98.4",
        "bs58": "^6.0.0",
        "bullmq": "^5.15.0",
        "dotenv": "^16.6.1",
        "fastify": "^4.28.1",
        "ioredis": "^5.4.1",
        "nanoid": "^3.3.7",
        "pg": "^8.13.1",
        "pino": "^9.5.0",
        "pino-pretty": "^13.0.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bn.js": "^5.2.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.19.5",
        "@types/pg": "^8.11.10",
        "@types/ws": "^8.5.13",
        "@typescript-eslint/eslint-plugin": "^8.18.2",
        "@typescript-eslint/parser": "^8.18.2",
        "eslint": "^9.17.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.9",
        "prettier": "^3.4.2",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
