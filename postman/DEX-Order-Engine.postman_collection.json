                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"type\": \"market\",\n  \"tokenIn\": \"USDC\",\n  \"tokenOut\": \"SOL\",\n  \"amountIn\": 100,\n  \"slippage\": 0.02\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/orders/execute",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "orders",
                        "execute"
                    ]
                },
                "description": "Execute a market order swapping 100 USDC for SOL with 2% slippage"
            }
        },
